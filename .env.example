# PE CoPilot — Local Development Configuration
# Copy this to .env and fill in your values

# App
DEBUG=true
API_KEY=dev-api-key-change-me

# GCP
GCP_PROJECT_ID=pe-copilot-dev
GCP_REGION=europe-west2

# Cloud Storage
GCS_RAW_UPLOADS_BUCKET=pe-copilot-raw-uploads
GCS_REPORTS_BUCKET=pe-copilot-reports

# Claude API (get your key from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid (free tier: https://signup.sendgrid.com)
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@pecopilot.com

# Firestore emulator (for local dev without GCP credentials)
# Uncomment to use the emulator:
# FIRESTORE_EMULATOR_HOST=localhost:8080
